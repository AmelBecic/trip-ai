# ── Environment template ─────────────────────────────────────────────
# Copy to `.env` and fill real values. `.env` is git-ignored — NEVER commit it.
# Document every secret the project needs HERE (names only, no real values).

# Example (delete what you don't use):
# DATABASE_URL=
# JWT_SECRET=
# GITHUB_TOKEN=            # fine-grained: PRs read/write for the code reviewer
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# ── Amadeus Self-Service, free test tier (TRIP-27) ───────────────────
# Register an app at developers.amadeus.com; the test tier is free and needs no
# card. Its host is test.api.amadeus.com and it serves sandbox data with limited
# coverage — not live inventory.
# Unset is fine for `npm run test`: the suite mocks the HTTP layer and CI has no
# credentials. These are needed to run the app against real prices.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
